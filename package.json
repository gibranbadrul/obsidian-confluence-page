{
	"name": "confluence-page-publisher",
	"version": "1.0.1",
	"description": "Publish notes to Confluence pages using frontmatter bindings and custom Markdown conversion.",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"check": "bun run lint && bun run test && bun run build",
		"version": "node scripts/update-version.mjs",
		"version:all": "UPDATE_VERSIONS_JSON=true node scripts/update-version.mjs"
	},
	"keywords": [
		"obsidian",
		"confluence"
	],
	"license": "MIT",
	"author": "gibranbadrul",
	"repository": {
		"type": "git",
		"url": "https://github.com/gibranbadrul/obsidian-confluence-page.git"
	},
	"bugs": {
		"url": "https://github.com/gibranbadrul/obsidian-confluence-page/issues"
	},
	"homepage": "https://github.com/gibranbadrul/obsidian-confluence-page#readme",
	"devDependencies": {
		"@eslint/js": "9.31.0",
		"@types/markdown-it": "14.1.2",
		"@types/node": "16.11.6",
		"@typescript-eslint/eslint-plugin": "8.37.0",
		"@typescript-eslint/parser": "8.37.0",
		"esbuild": "0.25.5",
		"eslint": "9.31.0",
		"eslint-plugin-obsidianmd": "0.4.1",
		"globals": "16.3.0",
		"tslib": "2.4.0",
		"typescript": "5.8.3",
		"vitest": "3.2.6"
	},
	"dependencies": {
		"js-base64": "^3.8.0",
		"markdown-it": "14.3.0",
		"obsidian": "latest"
	}
}
